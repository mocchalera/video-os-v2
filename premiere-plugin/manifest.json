{
  "manifestVersion": 5,
  "id": "com.videoos.premiere-watcher",
  "name": "Video OS Watcher",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "com.videoos.premiere-watcher.panel",
      "label": "Video OS Watcher",
      "minimumSize": { "width": 280, "height": 200 },
      "maximumSize": { "width": 600, "height": 400 },
      "preferredDockedSize": { "width": 280, "height": 250 },
      "preferredFloatingSize": { "width": 320, "height": 280 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": { "domains": [] },
    "clipboard": "readAndWrite"
  }
}
