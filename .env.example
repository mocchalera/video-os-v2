# Copy this file to .env.local for local development.
# scripts/analyze.ts and scripts/preflight.ts load .env.local first, then .env.

# Required for Gemini VLM analysis.
GEMINI_API_KEY=

# Recommended for the default Groq speech-to-text path.
GROQ_API_KEY=

# Optional alternative STT provider.
OPENAI_API_KEY=

# Optional. Required only if you enable pyannote speaker diarization.
HF_TOKEN=
