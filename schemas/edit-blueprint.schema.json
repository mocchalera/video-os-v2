{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/edit-blueprint.schema.json",
  "title": "Video OS Edit Blueprint",
  "type": "object",
  "required": [
    "sequence_goals",
    "beats",
    "pacing",
    "music_policy",
    "dialogue_policy",
    "transition_policy",
    "ending_policy",
    "rejection_rules"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "sequence_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/beat"
      }
    },
    "pacing": {
      "$ref": "#/$defs/pacing"
    },
    "music_policy": {
      "$ref": "#/$defs/musicPolicy"
    },
    "caption_policy": {
      "$ref": "#/$defs/captionPolicy"
    },
    "dialogue_policy": {
      "$ref": "#/$defs/dialoguePolicy"
    },
    "transition_policy": {
      "$ref": "#/$defs/transitionPolicy"
    },
    "ending_policy": {
      "$ref": "#/$defs/endingPolicy"
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "story_arc": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "strategy": {
          "type": "string",
          "enum": ["chronological", "peak_first", "testimonial_highlight", "problem_to_solution", "release_after_peak"]
        },
        "chronology_bias": { "type": "string" },
        "allow_time_reorder": { "type": "boolean" },
        "causal_links": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "resolved_profile": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string", "enum": ["explicit_hint", "inferred", "default"] },
        "rationale": { "type": "string" }
      },
      "additionalProperties": false
    },
    "resolved_policy": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string", "enum": ["explicit_hint", "inferred", "default"] },
        "rationale": { "type": "string" }
      },
      "additionalProperties": false
    },
    "active_editing_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dedupe_rules": {
      "type": "object",
      "properties": {
        "utterance_consumption": { "type": "string", "enum": ["unique", "allow_repeat"] },
        "semantic_similarity_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "allow_intentional_repetition": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "quality_targets": {
      "type": "object",
      "properties": {
        "hook_density_min": { "type": "number", "minimum": 0, "maximum": 1 },
        "novelty_rate_min": { "type": "number", "minimum": 0, "maximum": 1 },
        "duration_pacing_tolerance_pct": { "type": "number", "minimum": 0 },
        "emotion_gradient_min": { "type": "number", "minimum": 0, "maximum": 1 },
        "causal_connectivity_min": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "trim_policy": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["adaptive", "fixed", "center_first"] },
        "default_preferred_duration_frames": { "type": "integer", "minimum": 1 },
        "default_min_duration_frames": { "type": "integer", "minimum": 1 },
        "default_max_duration_frames": { "type": "integer", "minimum": 1 },
        "action_cut_guard": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "beat": {
      "type": "object",
      "required": [
        "id",
        "label",
        "target_duration_frames",
        "required_roles"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string"
        },
        "target_duration_frames": {
          "type": "integer",
          "minimum": 1
        },
        "required_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/beatRole"
          }
        },
        "preferred_roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/beatRole"
          }
        },
        "notes": {
          "type": "string"
        },
        "story_role": {
          "type": "string",
          "enum": ["hook", "setup", "experience", "closing"]
        },
        "skill_hints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "candidate_plan": {
          "type": "object",
          "properties": {
            "primary_candidate_ref": { "type": "string" },
            "fallback_candidate_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "candidate_constraints": {
          "type": "object",
          "properties": {
            "allow_interviewer_support": { "type": "boolean" },
            "force_unique_utterances": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "beatRole": {
      "type": "string",
      "enum": [
        "hero",
        "support",
        "transition",
        "texture",
        "dialogue"
      ]
    },
    "pacing": {
      "type": "object",
      "required": [
        "opening_cadence",
        "middle_cadence",
        "ending_cadence"
      ],
      "properties": {
        "opening_cadence": {
          "type": "string",
          "minLength": 1
        },
        "middle_cadence": {
          "type": "string",
          "minLength": 1
        },
        "ending_cadence": {
          "type": "string",
          "minLength": 1
        },
        "max_shot_length_frames": {
          "type": "integer",
          "minimum": 1
        },
        "confirmed_preferences": {
          "$ref": "#/$defs/confirmedPreferences"
        },
        "default_duration_target_sec": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "confirmedPreferences": {
      "type": "object",
      "required": [
        "mode",
        "source",
        "duration_target_sec",
        "confirmed_at"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["full", "collaborative"]
        },
        "source": {
          "type": "string",
          "enum": ["human_confirmed", "ai_autonomous"]
        },
        "duration_target_sec": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "confirmed_at": {
          "type": "string"
        },
        "structure_choice": {
          "type": "string"
        },
        "pacing_notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "musicPolicy": {
      "type": "object",
      "required": [
        "start_sparse",
        "allow_release_late",
        "entry_beat"
      ],
      "properties": {
        "start_sparse": {
          "type": "boolean"
        },
        "allow_release_late": {
          "type": "boolean"
        },
        "entry_beat": {
          "type": "string",
          "minLength": 1
        },
        "avoid_anthemic_lift": {
          "type": "boolean"
        },
        "permitted_energy_curve": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "captionPolicy": {
      "type": "object",
      "required": [
        "language",
        "delivery_mode",
        "source",
        "styling_class"
      ],
      "properties": {
        "language": {
          "type": "string",
          "minLength": 1
        },
        "delivery_mode": {
          "type": "string",
          "enum": [
            "burn_in",
            "sidecar",
            "both"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "transcript",
            "authored",
            "none"
          ]
        },
        "styling_class": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "dialoguePolicy": {
      "type": "object",
      "required": [
        "preserve_natural_breath",
        "avoid_wall_to_wall_voiceover"
      ],
      "properties": {
        "preserve_natural_breath": {
          "type": "boolean"
        },
        "avoid_wall_to_wall_voiceover": {
          "type": "boolean"
        },
        "prioritize_lines": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "transitionPolicy": {
      "type": "object",
      "required": [
        "prefer_match_texture_over_flashy_fx"
      ],
      "properties": {
        "prefer_match_texture_over_flashy_fx": {
          "type": "boolean"
        },
        "allow_hard_cuts": {
          "type": "boolean"
        },
        "avoid_speed_ramps": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "endingPolicy": {
      "type": "object",
      "required": [
        "should_feel"
      ],
      "properties": {
        "should_feel": {
          "type": "string",
          "minLength": 1
        },
        "final_line_strategy": {
          "type": "string"
        },
        "avoid_cta": {
          "type": "boolean"
        },
        "final_hold_min_frames": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
