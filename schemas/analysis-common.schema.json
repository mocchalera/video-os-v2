{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/analysis-common.schema.json",
  "title": "Video OS Analysis Common Definitions",
  "description": "Shared $defs for analysis artifact schemas (M2 Phase 1)",
  "$defs": {
    "confidence-record": {
      "type": "object",
      "required": ["score", "source", "status"],
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "label": { "type": "string" }
      },
      "additionalProperties": false
    },
    "provenance-record": {
      "type": "object",
      "required": ["stage", "method", "connector_version", "policy_hash", "request_hash"],
      "properties": {
        "stage": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "connector_version": { "type": "string", "minLength": 1 },
        "policy_hash": { "type": "string", "minLength": 1 },
        "request_hash": { "type": "string", "minLength": 1 },
        "model_alias": { "type": "string" },
        "model_snapshot": { "type": "string" },
        "prompt_hash": { "type": "string" },
        "response_format": { "type": "string" },
        "chunking_strategy": { "type": "string" },
        "ffmpeg_version": { "type": "string" },
        "provider_request_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "analysis-status": {
      "type": "string",
      "enum": ["pending", "ready", "partial", "skipped", "failed"]
    }
  }
}
