{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/selects-candidates.schema.json",
  "title": "Video OS Selects Candidates",
  "type": "object",
  "required": [
    "version",
    "project_id",
    "candidates"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "analysis_artifact_version": {
      "type": "string"
    },
    "selection_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "editorial_summary": {
      "type": "object",
      "properties": {
        "dominant_visual_mode": {
          "type": "string",
          "enum": ["talking_head", "screen_demo", "event_broll", "mixed", "unknown"]
        },
        "speaker_topology": {
          "type": "string",
          "enum": ["solo_primary", "interviewer_guest", "multi_speaker", "unknown"]
        },
        "motion_profile": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        },
        "transcript_density": {
          "type": "string",
          "enum": ["sparse", "medium", "dense", "unknown"]
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "$comment": "JSON Schema enforces non-negative source times. The validator runner must also enforce src_in_us < src_out_us for every candidate.",
      "required": [
        "segment_id",
        "asset_id",
        "src_in_us",
        "src_out_us",
        "role",
        "why_it_matches",
        "risks",
        "confidence"
      ],
      "properties": {
        "segment_id": {
          "type": "string",
          "minLength": 1
        },
        "asset_id": {
          "type": "string",
          "minLength": 1
        },
        "src_in_us": {
          "type": "integer",
          "minimum": 0
        },
        "src_out_us": {
          "type": "integer",
          "minimum": 0
        },
        "role": {
          "type": "string",
          "enum": [
            "hero",
            "support",
            "transition",
            "texture",
            "dialogue",
            "reject"
          ]
        },
        "why_it_matches": {
          "type": "string",
          "minLength": 1
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "semantic_rank": {
          "type": "integer",
          "minimum": 1
        },
        "quality_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "eligible_beats": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "transcript_excerpt": {
          "type": "string"
        },
        "motif_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rejection_reason": {
          "type": "string"
        },
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "utterance_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "speaker_role": {
          "type": "string",
          "enum": ["primary", "interviewer", "secondary", "unknown"]
        },
        "semantic_dedupe_key": {
          "type": "string"
        },
        "editorial_signals": {
          "type": "object",
          "properties": {
            "silence_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "afterglow_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "speech_intensity_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "reaction_intensity_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "authenticity_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "surprise_signal": { "type": "number", "minimum": 0, "maximum": 1 },
            "hope_signal": { "type": "number", "minimum": 0, "maximum": 1 },
            "face_detected": { "type": "boolean" },
            "visual_tags": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "semantic_cluster_id": { "type": "string" }
          },
          "additionalProperties": false
        },
        "trim_hint": {
          "type": "object",
          "properties": {
            "source_center_us": { "type": "integer", "minimum": 0 },
            "preferred_duration_us": { "type": "integer", "minimum": 1 },
            "min_duration_us": { "type": "integer", "minimum": 1 },
            "max_duration_us": { "type": "integer", "minimum": 1 },
            "window_start_us": { "type": "integer", "minimum": 0 },
            "window_end_us": { "type": "integer", "minimum": 0 },
            "interest_point_label": { "type": "string" },
            "interest_point_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "role": {
                "const": "reject"
              }
            },
            "required": [
              "role"
            ]
          },
          "then": {
            "required": [
              "rejection_reason"
            ]
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
