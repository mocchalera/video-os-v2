{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/script-draft.schema.json",
  "title": "Video OS Script Draft (Operational)",
  "type": "object",
  "required": ["version", "project_id", "beat_assignments"],
  "properties": {
    "version": { "type": "string" },
    "project_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "delivery_order": {
      "type": "array",
      "items": { "type": "string" }
    },
    "beat_assignments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["beat_id", "primary_candidate_ref"],
        "properties": {
          "beat_id": { "type": "string" },
          "primary_candidate_ref": { "type": "string" },
          "backup_candidate_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "story_role": {
            "type": "string",
            "enum": ["hook", "setup", "experience", "closing"]
          },
          "transition_proposal": { "type": "string" },
          "active_skill_hints": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rationale": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
