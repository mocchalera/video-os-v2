{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/creative-brief.schema.json",
  "title": "Video OS Creative Brief",
  "type": "object",
  "required": [
    "project",
    "message",
    "audience",
    "emotion_curve",
    "must_have",
    "must_avoid",
    "autonomy",
    "resolved_assumptions"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "object",
      "required": [
        "title",
        "strategy"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "client": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "runtime_target_sec": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "message": {
      "type": "object",
      "required": [
        "primary"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "audience": {
      "type": "object",
      "required": [
        "primary"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excluded": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "emotion_curve": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "must_have": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "must_avoid": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "autonomy": {
      "type": "object",
      "required": [
        "may_decide",
        "must_ask"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["full", "collaborative"]
        },
        "may_decide": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "must_ask": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "resolved_assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_interpretations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "content_hint": {
      "type": "string",
      "description": "Free-text hint describing what the footage contains, used to improve VLM recognition accuracy (e.g. 'child learning to ride a bicycle')"
    },
    "editorial": {
      "type": "object",
      "properties": {
        "distribution_channel": {
          "type": "string",
          "enum": ["web_lp", "social_feed", "product_page", "presentation", "event_recap", "unknown"]
        },
        "aspect_ratio": {
          "type": "string",
          "enum": ["16:9", "9:16", "1:1", "4:5", "unknown"]
        },
        "embed_context": {
          "type": "string",
          "enum": ["standalone", "lp_embed", "deck_insert", "kiosk", "unknown"]
        },
        "hook_priority": {
          "type": "string",
          "enum": ["credibility_first", "balanced", "aggressive"]
        },
        "credibility_bias": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "profile_hint": { "type": "string" },
        "policy_hint": { "type": "string" },
        "allow_inference": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
