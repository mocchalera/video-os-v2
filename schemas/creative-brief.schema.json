{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/creative-brief.schema.json",
  "title": "Video OS Creative Brief",
  "type": "object",
  "required": [
    "project",
    "message",
    "audience",
    "emotion_curve",
    "must_have",
    "must_avoid",
    "autonomy",
    "resolved_assumptions"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "object",
      "required": [
        "title",
        "strategy"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "client": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "runtime_target_sec": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "message": {
      "type": "object",
      "required": [
        "primary"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "audience": {
      "type": "object",
      "required": [
        "primary"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excluded": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "emotion_curve": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "must_have": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "must_avoid": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "autonomy": {
      "type": "object",
      "required": [
        "may_decide",
        "must_ask"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["full", "collaborative"]
        },
        "may_decide": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "must_ask": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "resolved_assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_interpretations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
