{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/material-reading.schema.json",
  "title": "Video OS Material Reading (Operational)",
  "type": "object",
  "required": ["version", "project_id", "beat_readings"],
  "properties": {
    "version": { "type": "string" },
    "project_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "beat_readings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["beat_id", "top_candidates"],
        "properties": {
          "beat_id": { "type": "string" },
          "top_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["candidate_ref", "why_primary"],
              "properties": {
                "candidate_ref": { "type": "string" },
                "why_primary": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "backup_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["candidate_ref"],
              "properties": {
                "candidate_ref": { "type": "string" },
                "why_backup": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "coverage_gaps": {
            "type": "array",
            "items": { "type": "string" }
          },
          "asset_concentration": { "type": "number" },
          "speaker_risks": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tone_risks": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "dedupe_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "candidate_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
